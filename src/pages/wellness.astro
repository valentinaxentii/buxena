---
import BaseLayout from '../layouts/BaseLayout.astro';
import Figure from '../components/Figure.astro';
import QuoteBand from '../components/QuoteBand.astro';

const rounds = [
  {
    n: '01',
    title: 'Heat',
    body: 'Sit for as long as it stays comfortable and no longer. Ten to fifteen minutes is a common first round. The upper bench is hotter than the lower one — start low.',
  },
  {
    n: '02',
    title: 'Löyly',
    body: 'A ladle of water on the stones lifts the humidity sharply and the room feels hotter within seconds. Add it gradually. This is the part people build the ritual around.',
  },
  {
    n: '03',
    title: 'Cool',
    body: 'Leave before you want to. Step outside, take a cool shower, sit down. The contrast is the point, and rushing it is the most common mistake.',
  },
  {
    n: '04',
    title: 'Rest',
    body: 'Wait until your breathing has settled and you feel genuinely cool again. Then decide whether to go back in. Two or three rounds is typical.',
  },
];
---

<BaseLayout
  title="Wellness"
  description="How to use a sauna well — the heat, cold and rest cycle, etiquette, and practical guidance for getting the most from the room."
>
  <section class="band band--tight page-head">
    <div class="shell">
      <span class="eyebrow">The Ritual</span>
      <h1 class="display measure--tight">Heat, cold, rest — and then again</h1>
      <p class="lead measure">
        A sauna rewards patience more than endurance. The rhythm below is the one
        used across northern Europe, and it is worth learning before you buy.
      </p>
    </div>
  </section>

  <section class="band">
    <div class="shell">
      <ol class="rounds reveal">
        {rounds.map((r) => (
          <li class="round">
            <span class="round__n">{r.n}</span>
            <div>
              <h2 class="h3 round__title">{r.title}</h2>
              <p class="round__body">{r.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="band band--birch">
    <div class="shell split">
      <div class="split__media reveal">
        <Figure
          alt="Water being poured onto heater stones"
          note="WELLNESS — löyly moment: water hitting the stones, steam rising. Backlit against a dark interior. This is the signature image of the page."
          ratio="4 / 5"
          tone="dark"
        />
      </div>
      <div class="split__text reveal">
        <span class="eyebrow">Etiquette</span>
        <h2 class="h2">A few conventions worth keeping</h2>
        <p>
          Sit on a towel. Shower before you go in. Keep the door closed and open it
          decisively rather than slowly — a slow door loses more heat than a quick one.
        </p>
        <p>
          Ask before adding water if you are not alone; humidity is a shared
          decision. Keep conversation quiet or absent. Take off jewellery and
          anything metal.
        </p>
        <p>
          Drink water between rounds, and leave the room whenever it stops being
          pleasant. Nothing about a sauna is improved by pushing through.
        </p>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="shell shell--narrow">
      <div class="disclaimer">
        <span class="eyebrow">Please note</span>
        <p>
          BUXENA makes no medical or therapeutic claims about sauna use. Heat
          exposure is not appropriate for everyone — including during pregnancy,
          with cardiovascular conditions, with certain medications, or in
          combination with alcohol.
        </p>
        <p>
          If you have any health condition, or you are unsure whether sauna use is
          suitable for you, speak to a physician before starting. This page is
          general guidance on how the room is traditionally used, nothing more.
        </p>
      </div>
    </div>
  </section>

  <QuoteBand />
</BaseLayout>

<style>
  .page-head .lead { margin-top: 1.75rem; }

  .rounds {
    display: grid;
    gap: 0;
  }
  .round {
    display: grid;
    grid-template-columns: minmax(0, 5rem) minmax(0, 1fr);
    gap: clamp(1.25rem, 0.5rem + 2.5vw, 3.5rem);
    padding-block: clamp(1.75rem, 1rem + 2vw, 2.75rem);
    border-top: 1px solid var(--line);
    align-items: start;
  }
  .round:last-child { border-bottom: 1px solid var(--line); }

  .round__n {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.4rem + 2vw, 3.25rem);
    line-height: 1;
    color: var(--bronze);
  }
  .round__title { margin-bottom: 0.7rem; }
  .round__body { color: var(--muted); max-width: 42em; }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: clamp(2rem, 0.5rem + 5vw, 6rem);
    align-items: center;
  }
  .split__text .h2 { margin-bottom: 1.75rem; }

  .disclaimer {
    border-top: 2px solid var(--ink);
    padding-top: 2rem;
  }
  .disclaimer p { font-size: var(--t-small); color: var(--muted); line-height: 1.8; }

  @media (max-width: 900px) {
    .split { grid-template-columns: 1fr; }
    .round { grid-template-columns: 1fr; gap: 0.75rem; }
  }
</style>
