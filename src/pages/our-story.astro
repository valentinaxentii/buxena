---
import BaseLayout from '../layouts/BaseLayout.astro';
import Figure from '../components/Figure.astro';
import QuoteBand from '../components/QuoteBand.astro';
import { showDev } from '../data/site';

const values = [
  {
    title: 'Curated, not stocked',
    body: 'We select a short range from European makers and learn it completely. That is worth more to you than a catalogue nobody has stood inside.',
  },
  {
    title: 'The site comes first',
    body: 'Every recommendation starts with your space — its dimensions, its power, its access — not with what we would like to sell.',
  },
  {
    title: 'Say the difficult thing early',
    body: 'Permits, electrical work, a base that needs pouring. Better to hear it in week one than on delivery day.',
  },
];
---

<BaseLayout
  title="Our Story"
  description="Why BUXENA exists, what we select for, and how we work with the people who buy from us."
>
  <section class="band band--tight page-head">
    <div class="shell">
      <span class="eyebrow">Our Story</span>
      <h1 class="display measure--tight">
        We started with a simple frustration
      </h1>
      <p class="lead measure">
        Buying a sauna in the United States is harder than it should be. The
        listings are thin, the specifications are vague, and the people answering
        the phone have often never stood inside the product they are selling.
      </p>
    </div>
  </section>

  <section class="band">
    <div class="shell split">
      <div class="split__text reveal">
        <h2 class="h2">A northern habit, moved south</h2>
        <p>
          In northern Europe the sauna is not a luxury item. It is a room in the
          house, used weekly, built to a set of conventions worked out over a very
          long time. Nobody there thinks of it as an installation. It is closer to
          a kitchen: ordinary, essential, and worth doing properly.
        </p>
        <p>
          BUXENA exists to bring that standard to American homes without the
          guesswork. We do not manufacture — we curate and import. Our work is
          choosing European makers worth representing, specifying against your
          actual space, and staying involved through delivery.
        </p>
        <p>
          We are deliberately small. That is a constraint on how fast we can grow
          and an advantage in how well we can answer a question.
        </p>
        {showDev && (
          <p class="note">
            DEV NOTE — founding year, team and supplier relationships to be added.
            Hidden in production.
          </p>
        )}
      </div>
      <div class="split__media reveal">
        <Figure
          alt="Sauna interior, empty and quiet"
          note="STORY — a quiet, empty sauna interior. No people. Warm light, strong horizontal bench lines. Should feel calm and unstaged."
          ratio="4 / 5"
          tone="mid"
        />
      </div>
    </div>
  </section>

  <section class="band band--ember">
    <div class="shell">
      <div class="sec-head reveal">
        <span class="eyebrow">How We Work</span>
        <h2 class="h2 measure--tight">Three commitments</h2>
      </div>
      <div class="grid cols-3 reveal">
        {values.map((v) => (
          <div class="value">
            <span class="slats" aria-hidden="true"></span>
            <h3 class="h3 value__title">{v.title}</h3>
            <p class="value__body">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <QuoteBand />
</BaseLayout>

<style>
  .page-head .lead { margin-top: 1.75rem; }
  .page-head .display { margin-top: 0; }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.85fr);
    gap: clamp(2rem, 0.5rem + 5vw, 6rem);
    align-items: center;
  }
  .split__text .h2 { margin-bottom: 1.75rem; }

  .note {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    font-size: 0.8125rem;
    color: var(--muted);
    font-style: italic;
  }

  .value .slats { color: var(--bronze-soft); margin-bottom: 1.75rem; }
  .value__title { margin-bottom: 0.85rem; }
  .value__body { font-size: var(--t-small); color: var(--muted-dark); line-height: 1.75; }

  @media (max-width: 900px) {
    .split { grid-template-columns: 1fr; }
    .split__media { order: -1; }
  }
</style>
