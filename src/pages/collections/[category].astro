---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import QuoteBand from '../../components/QuoteBand.astro';
import { categories } from '../../data/site';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const models = await getCollection('saunas', ({ data }) => !data.draft);
  // Only build pages for categories that contain a model. Add a heater and its
  // page, footer link and filter chip all appear automatically.
  return categories
    .filter((c) => models.some((m) => m.data.category === c.id))
    .map((c) => ({ params: { category: c.id }, props: { category: c } }));
}

const { category } = Astro.props;

const models = (await getCollection('saunas', ({ data }) => !data.draft && data.category === category.id))
  .sort((a, b) => a.data.order - b.data.order);

const allModels = await getCollection('saunas', ({ data }) => !data.draft);
const others = categories.filter(
  (c) => c.id !== category.id && allModels.some((m) => m.data.category === c.id)
);
---

<BaseLayout
  title={category.name}
  description={`${category.name} from BUXENA — ${category.blurb}`}
>
  <section class="band band--tight page-head">
    <div class="shell">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/saunas/">Saunas</a>
        <span aria-hidden="true">/</span>
        <span>{category.name}</span>
      </nav>
      <h1 class="display measure--tight">{category.name}</h1>
      <p class="lead measure">{category.blurb}</p>
    </div>
  </section>

  <section class="band">
    <div class="shell">
      {models.length > 0 && (
        <div class="grid cols-3">
          {models.map((s) => (
            <ProductCard
              slug={s.id}
              title={s.data.title}
              tagline={s.data.tagline}
              category={s.data.category}
              placeholder={s.data.placeholder}
              image={s.data.heroImage}
            />
          ))}
        </div>
      )}

      {others.length > 0 && (
      <div class="others">
        <span class="eyebrow">Other collections</span>
        <ul class="others__list">
          {others.map((c) => (
            <li><a class="link" href={`/collections/${c.id}/`}>{c.name}</a></li>
          ))}
        </ul>
      </div>
      )}
    </div>
  </section>

  <QuoteBand />
</BaseLayout>

<style>
  .page-head { padding-bottom: 0; }
  .page-head .lead { margin-top: 1.75rem; }

  .crumbs {
    display: flex;
    gap: 0.75rem;
    font-size: var(--t-label);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: clamp(1.75rem, 1rem + 2vw, 3rem);
  }
  .crumbs a { text-decoration: none; }
  .crumbs a:hover { color: var(--ink); }

  .empty {
    color: var(--muted);
    font-style: italic;
    font-size: var(--t-lead);
    max-width: 32em;
  }

  .others {
    margin-top: clamp(3rem, 2rem + 3vw, 5rem);
    padding-top: 2.5rem;
    border-top: 1px solid var(--line);
  }
  .others__list { display: flex; flex-wrap: wrap; gap: 1.25rem 2.25rem; }
</style>
