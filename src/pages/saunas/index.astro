---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import QuoteBand from '../../components/QuoteBand.astro';
import { categories } from '../../data/site';
import { getCollection } from 'astro:content';

const saunas = (await getCollection('saunas', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

const used = categories.filter((c) => saunas.some((s) => s.data.category === c.id));
---

<BaseLayout
  title="Saunas"
  description="Browse the BUXENA range — outdoor cabins, indoor rooms, barrel saunas, modern cubes, heaters and accessories."
>
  <section class="band band--tight page-head">
    <div class="shell">
      <span class="eyebrow">The Range</span>
      <h1 class="display measure--tight">Every model, in one place</h1>
      <p class="lead measure">
        Filter by type, or work through the whole range. Each model has its own
        page with dimensions, materials and heater options.
      </p>
    </div>
  </section>

  <section class="band band--tight">
    <div class="shell">
      <div class="filters" role="group" aria-label="Filter saunas by type">
        <button class="chip is-on" type="button" data-filter="all" aria-pressed="true">
          All <span class="chip__n">{saunas.length}</span>
        </button>
        {used.map((c) => (
          <button class="chip" type="button" data-filter={c.id} aria-pressed="false">
            {c.short}
            <span class="chip__n">{saunas.filter((s) => s.data.category === c.id).length}</span>
          </button>
        ))}
      </div>

      <div class="grid cols-3" data-product-grid>
        {saunas.map((s) => (
          <ProductCard
            slug={s.id}
            title={s.data.title}
            tagline={s.data.tagline}
            category={s.data.category}
            placeholder={s.data.placeholder}
            image={s.data.heroImage}
          />
        ))}
      </div>

      <p class="empty" data-empty hidden>Nothing in that category yet.</p>
    </div>
  </section>

  <QuoteBand
    heading="Not sure which one fits?"
    body="Send us the dimensions of the space and how many people you want to seat. We will tell you which models work and which do not."
  />
</BaseLayout>

<style>
  .page-head { padding-bottom: 0; }
  .page-head .lead { margin-top: 1.75rem; }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding-bottom: clamp(2rem, 1.2rem + 2vw, 3.25rem);
    margin-bottom: clamp(2rem, 1.2rem + 2vw, 3.25rem);
    border-bottom: 1px solid var(--line);
  }

  .chip {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    background: none;
    border: 1px solid var(--line);
    padding: 0.65rem 1.25rem;
    font-size: var(--t-label);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.35s var(--ease), color 0.35s var(--ease),
      border-color 0.35s var(--ease);
  }
  .chip:hover { border-color: var(--ink); }
  .chip.is-on { background: var(--ember); color: var(--linen); border-color: var(--ember); }

  .chip__n { font-family: var(--font-display); font-size: 0.8rem; letter-spacing: 0; opacity: 0.65; }

  .empty { color: var(--muted); font-style: italic; padding-block: 3rem; }
</style>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const cards = document.querySelectorAll<HTMLElement>('[data-product-grid] .pcard');
  const empty = document.querySelector<HTMLElement>('[data-empty]');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter;

      chips.forEach((c) => {
        const on = c === chip;
        c.classList.toggle('is-on', on);
        c.setAttribute('aria-pressed', String(on));
      });

      let shown = 0;
      cards.forEach((card) => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.hidden = !match;
        if (match) shown++;
      });

      if (empty) empty.hidden = shown > 0;
    });
  });
</script>
