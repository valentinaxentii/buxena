---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Figure from '../../components/Figure.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import ProductCard from '../../components/ProductCard.astro';
import { categoryMap, showDev } from '../../data/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const saunas = await getCollection('saunas', ({ data }) => !data.draft);
  return saunas.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const cat = categoryMap[data.category];

// Sibling models in the same collection
const all = await getCollection('saunas', ({ data: d }) => !d.draft);
const related = all
  .filter((s) => s.data.category === data.category && s.id !== entry.id)
  .slice(0, 3);

const TBC = 'To be confirmed';

/**
 * Specification handling.
 *
 * In production, anything without a verified value is simply omitted — a
 * customer never sees a column of "To be confirmed". If nothing at all is
 * verified, the whole sidebar is hidden and the description runs full width.
 *
 * In development every field is shown, so you can see what is still missing.
 */
const verifiedRows = [
  { label: 'Collection', value: cat?.name ?? data.category },
  ...(data.capacity ? [{ label: 'Capacity', value: data.capacity }] : []),
  ...(data.dimensions ?? []),
  ...(data.specs ?? []),
];

const pendingRows = [
  ...(data.capacity ? [] : [{ label: 'Capacity', value: TBC }]),
  ...(data.dimensions ? [] : [{ label: 'Dimensions', value: TBC }]),
];

const specRows = showDev ? [...verifiedRows, ...pendingRows] : verifiedRows;

const blocks = [
  { title: 'Materials', items: data.materials },
  { title: 'Heater options', items: data.heaterOptions },
  { title: 'Features', items: data.features },
];

const hasDownloads = (data.downloads ?? []).some((d) => d.file);

// Is there anything worth showing a customer beyond the collection name?
const hasVerifiedDetail =
  verifiedRows.length > 1 || blocks.some((b) => b.items?.length) || hasDownloads;

const showSpecs = showDev || hasVerifiedDetail;
---

<BaseLayout title={data.title} description={data.summary}>
  <article>
    <!-- Header -->
    <section class="band band--tight prod-head">
      <div class="shell">
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/saunas/">Saunas</a>
          <span aria-hidden="true">/</span>
          <a href={`/collections/${data.category}/`}>{cat?.name}</a>
        </nav>

        <div class="prod-head__grid">
          <div>
            <h1 class="display">{data.title}</h1>
            <p class="prod-head__tag serif-italic">{data.tagline}</p>
          </div>
          <div class="prod-head__side">
            <p class="lead">{data.summary}</p>
            <a class="btn btn--bronze" href="#enquire">Request a Quote</a>
          </div>
        </div>
      </div>
    </section>

    {data.placeholder && showDev && (
      <div class="shell">
        <p class="notice">
          <strong>Placeholder listing.</strong> Images, dimensions, materials and
          heater options for this model are not yet published. Nothing on this page
          should be treated as a specification.
        </p>
      </div>
    )}

    <!-- Gallery -->
    <section class="band band--tight">
      <div class="shell">
        <Figure
          src={data.heroImage.src}
          alt={data.heroImage.alt}
          note={data.heroImage.note}
          ratio="16 / 9"
          tone="dark"
          priority={true}
        />

        {data.gallery.length > 0 && (
          <div class="gallery">
            {data.gallery.map((img) => (
              <Figure src={img.src} alt={img.alt} note={img.note} ratio="4 / 3" tone="mid" />
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Description + specs -->
    <section class="band">
      <div class={`shell prod-body ${showSpecs ? "" : "prod-body--solo"}`}>
        <div class="prose">
          <span class="eyebrow">About this model</span>
          <Content />
        </div>

        {showSpecs && (
          <aside class="specs">
            <h2 class="specs__h">Specifications</h2>
            <dl class="specs__list">
              {specRows.map((row) => (
                <div class="specs__row">
                  <dt>{row.label}</dt>
                  <dd class={row.value === TBC ? 'is-tbc' : ''}>{row.value}</dd>
                </div>
              ))}
            </dl>

            {blocks.map((block) =>
              block.items?.length ? (
                <Fragment>
                  <h3 class="specs__sub">{block.title}</h3>
                  <ul class="specs__ul">{block.items.map((i) => <li>{i}</li>)}</ul>
                </Fragment>
              ) : showDev ? (
                <Fragment>
                  <h3 class="specs__sub">{block.title}</h3>
                  <p class="is-tbc">{TBC}</p>
                </Fragment>
              ) : null
            )}

            {hasDownloads ? (
              <Fragment>
                <h3 class="specs__sub">Downloads</h3>
                <ul class="specs__ul">
                  {data.downloads!.filter((d) => d.file).map((d) => (
                    <li><a class="dl" href={d.file} download>{d.label}</a></li>
                  ))}
                </ul>
              </Fragment>
            ) : showDev ? (
              <Fragment>
                <h3 class="specs__sub">Downloads</h3>
                <p class="is-tbc">Specification sheet not yet available.</p>
              </Fragment>
            ) : null}
          </aside>
        )}
      </div>
    </section>

    <!-- Enquiry -->
    <section class="band band--birch" id="enquire">
      <div class="shell shell--narrow">
        <div class="sec-head center">
          <span class="eyebrow">Enquire</span>
          <h2 class="h2">Request a quote for the {data.title}</h2>
        </div>
        <QuoteForm preselect={data.title} />
      </div>
    </section>

    {related.length > 0 && (
      <section class="band">
        <div class="shell">
          <div class="sec-head">
            <span class="eyebrow">Also in {cat?.name}</span>
          </div>
          <div class="grid cols-3">
            {related.map((s) => (
              <ProductCard
                slug={s.id}
                title={s.data.title}
                tagline={s.data.tagline}
                category={s.data.category}
                placeholder={s.data.placeholder}
                image={s.data.heroImage}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .prod-head { padding-bottom: 0; }

  .crumbs {
    display: flex;
    gap: 0.75rem;
    font-size: var(--t-label);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: clamp(1.75rem, 1rem + 2vw, 3rem);
  }
  .crumbs a { text-decoration: none; }
  .crumbs a:hover { color: var(--ink); }

  .prod-head__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(1.75rem, 0.5rem + 4vw, 5rem);
    align-items: end;
  }
  .prod-head__tag {
    font-size: clamp(1.15rem, 0.9rem + 0.9vw, 1.65rem);
    color: var(--bronze-ink);
    margin-top: 1rem;
  }
  .prod-head__side .lead { margin-bottom: 2rem; }

  .notice {
    border: 1px solid var(--line);
    border-left: 3px solid var(--bronze);
    background: var(--linen-deep);
    padding: 1.15rem 1.5rem;
    font-size: var(--t-small);
    color: var(--muted);
    margin-top: 2.5rem;
  }
  .notice strong { color: var(--ink); font-weight: 500; }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(0.75rem, 0.4rem + 1.2vw, 1.5rem);
    margin-top: clamp(0.75rem, 0.4rem + 1.2vw, 1.5rem);
  }

  .prod-body--solo { grid-template-columns: minmax(0, 1fr); max-width: 52rem; }
  .prod-body {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
    gap: clamp(2.5rem, 1rem + 5vw, 6rem);
    align-items: start;
  }

  .prose :global(p) { margin-bottom: 1.3em; }
  .prose :global(p:first-of-type) { font-size: var(--t-lead); line-height: 1.72; }
  .prose :global(strong) { font-weight: 500; }

  .specs {
    border-top: 2px solid var(--ink);
    padding-top: 1.75rem;
  }
  .specs__h {
    font-family: var(--font-sans);
    font-size: var(--t-label);
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
  }
  .specs__list { margin: 0 0 2.25rem; }
  .specs__row {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--line);
    font-size: var(--t-small);
  }
  .specs__row dt { color: var(--muted); margin: 0; }
  .specs__row dd { margin: 0; text-align: right; }

  .specs__sub {
    font-family: var(--font-sans);
    font-size: var(--t-label);
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 2rem 0 0.9rem;
  }
  .specs__ul { font-size: var(--t-small); }
  .specs__ul li { padding: 0.45rem 0; border-bottom: 1px solid var(--line); }

  .is-tbc { color: var(--muted); font-style: italic; opacity: 0.85; }
  .specs p.is-tbc { font-size: var(--t-small); margin: 0; }

  .dl { color: var(--bronze-ink); }

  @media (max-width: 900px) {
    .prod-head__grid, .prod-body { grid-template-columns: 1fr; }
    .prod-head__grid { align-items: start; }
  }
  @media (max-width: 560px) {
    .gallery { grid-template-columns: 1fr; }
  }
</style>
