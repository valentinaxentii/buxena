---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" noindex={true}>
  <section class="band nf">
    <div class="shell shell--narrow center">
      <span class="eyebrow">404</span>
      <h1 class="display">This room does not exist</h1>
      <p class="lead">The page you were looking for is not here.</p>
      <div class="nf__actions">
        <a class="btn btn--solid" href="/">Return home</a>
        <a class="btn btn--outline" href="/saunas/">Browse the saunas</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { padding-block: clamp(6rem, 4rem + 10vw, 12rem); }
  .nf .lead { margin: 1.5rem auto 0; }
  .nf__actions { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 3rem; }
</style>
