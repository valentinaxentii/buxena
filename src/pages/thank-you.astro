---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank you" description="Your request has been received." noindex={true}>
  <section class="band ty">
    <div class="shell shell--narrow center">
      <span class="slats mx-auto ty__slats" aria-hidden="true"></span>
      <h1 class="display">Request received</h1>
      <p class="lead">
        Thank you. We have your enquiry and will come back to you with options
        and a written quote.
      </p>
      <div class="ty__actions">
        <a class="btn btn--solid" href="/saunas/">Back to the saunas</a>
        <a class="btn btn--outline" href="/wellness/">Read about the ritual</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .ty { padding-block: clamp(6rem, 4rem + 10vw, 12rem); }
  .ty__slats { color: var(--bronze); margin-bottom: 2.5rem; }
  .ty .lead { margin: 1.75rem auto 0; max-width: 34em; }
  .ty__actions { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 3rem; }
</style>
