---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, publicEmail, showDev } from '../data/site';
---

<BaseLayout title="Contact" description="Get in touch with BUXENA.">
  <section class="band page-head">
    <div class="shell contact">
      <div>
        <span class="eyebrow">Contact</span>
        <h1 class="display">Get in touch</h1>
        <p class="lead measure">
          For quotes, specifications, or a question about whether a particular
          model suits your space — send us the details and we will answer them
          ourselves. The quote form is the fastest route to a useful reply.
        </p>
      </div>

      <div class="contact__details">
        <dl>
          {publicEmail && (
            <div class="row">
              <dt>Email</dt>
              <dd><a href={`mailto:${publicEmail}`}>{publicEmail}</a></dd>
            </div>
          )}
          {site.phone && (
            <div class="row">
              <dt>Phone</dt>
              <dd><a href={`tel:${site.phone.replace(/[^+\d]/g, '')}`}>{site.phone}</a></dd>
            </div>
          )}
          {site.city && (
            <div class="row"><dt>Based in</dt><dd>{site.city}</dd></div>
          )}
          <div class="row"><dt>Serving</dt><dd>United States</dd></div>
        </dl>

        <a class="btn btn--bronze contact__cta" href="/quote/">Request a Quote</a>

        {showDev && (
          <p class="contact__note">
            DEV NOTE — email is unconfirmed and hidden in production. Phone,
            hours and location pending. Hidden in production.
          </p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.85fr);
    gap: clamp(2.5rem, 1rem + 5vw, 6rem);
    align-items: start;
  }
  .contact .lead { margin-top: 1.75rem; }

  .contact__details { border-top: 2px solid var(--ink); padding-top: 1.75rem; }
  .row {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--line);
    font-size: var(--t-small);
  }
  .row dt { color: var(--muted); margin: 0; }
  .row dd { margin: 0; text-align: right; }
  .row a { color: var(--bronze-ink); text-decoration: none; }
  .row a:hover { color: var(--ink); }

  .contact__cta { margin-top: 2rem; }
  .contact__note { margin-top: 1.75rem; font-size: 0.8125rem; font-style: italic; color: var(--muted); }

  @media (max-width: 900px) { .contact { grid-template-columns: 1fr; } }
</style>
