---
import Figure from './Figure.astro';
import { categoryMap, showDev } from '../data/site';

interface Props {
  slug: string;
  title: string;
  tagline: string;
  category: string;
  placeholder?: boolean;
  image?: { src?: string; alt: string; note?: string };
}
const { slug, title, tagline, category, placeholder = true, image } = Astro.props;
const cat = categoryMap[category];
---

<article class="pcard" data-category={category}>
  <a class="pcard__link" href={`/saunas/${slug}/`}>
    <div class="pcard__media">
      <Figure
        src={image?.src}
        alt={image?.alt ?? title}
        note={image?.note}
        ratio="4 / 3"
        tone="mid"
      />
      {placeholder && showDev && <span class="pcard__flag">Placeholder listing</span>}
    </div>
    <div class="pcard__body">
      <span class="pcard__cat">{cat?.short ?? category}</span>
      <h3 class="pcard__title">{title}</h3>
      <p class="pcard__tag">{tagline}</p>
      <span class="pcard__more">View details</span>
    </div>
  </a>
</article>

<style>
  .pcard__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .pcard__media { position: relative; overflow: hidden; }
  .pcard__media :global(.fig) { transition: transform 1.1s var(--ease); }
  .pcard__link:hover .pcard__media :global(.fig) { transform: scale(1.035); }

  .pcard__flag {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    z-index: 2;
    background: rgba(27, 25, 23, 0.82);
    color: var(--linen);
    font-size: 0.5625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.4rem 0.7rem;
  }

  .pcard__body { padding-top: 1.35rem; }

  .pcard__cat {
    display: block;
    font-size: var(--t-label);
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--bronze-ink);
    margin-bottom: 0.75rem;
  }

  .pcard__title { font-size: var(--t-h3); margin-bottom: 0.5rem; }

  .pcard__tag {
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .pcard__more {
    font-size: var(--t-label);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--line);
    transition: border-color 0.4s var(--ease);
  }
  .pcard__link:hover .pcard__more { border-bottom-color: var(--ink); }
</style>
