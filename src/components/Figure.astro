---
import { showDev } from '../data/site';

/**
 * Figure — the only way images enter the site.
 *
 * If `src` is set it renders a real <img>.
 * If not, it renders a clearly-labelled PLACEHOLDER block showing the
 * art-direction note, so nobody mistakes it for finished work.
 *
 * Swapping in real photography is a one-line change: add `src`.
 */
interface Props {
  src?: string;
  alt: string;
  note?: string;
  ratio?: string;      // any CSS aspect-ratio, e.g. "4 / 5"
  tone?: 'light' | 'mid' | 'dark';
  priority?: boolean;  // hero images only — skips lazy loading
  class?: string;
}

const {
  src,
  alt,
  note,
  ratio = '4 / 3',
  tone = 'mid',
  priority = false,
  class: className = '',
} = Astro.props;

/**
 * Two placeholder modes.
 *   dev  — labelled block showing the art-direction note, so you can see
 *          exactly which shot is still outstanding.
 *   prod — a quiet, unlabelled tone block. It says nothing false and never
 *          announces to a customer that the site is unfinished.
 */
const labelled = showDev;
---

<figure class={`fig fig--${tone} ${className}`} style={`--fig-ratio:${ratio}`}>
  {
    src ? (
      <img
        src={src}
        alt={alt}
        loading={priority ? 'eager' : 'lazy'}
        decoding="async"
        fetchpriority={priority ? 'high' : 'auto'}
      />
    ) : (
      <div class="fig__ph" role="img" aria-label={labelled ? `Placeholder image. ${alt}` : alt}>
        <div class="fig__grain" aria-hidden="true"></div>
        {labelled && (
          <div class="fig__body">
            <span class="fig__tag">Placeholder image</span>
            <p class="fig__note">{note ?? alt}</p>
          </div>
        )}
      </div>
    )
  }
</figure>

<style>
  .fig {
    margin: 0;
    position: relative;
    overflow: hidden;
    aspect-ratio: var(--fig-ratio);
    background: var(--birch);
  }

  .fig img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fig__ph {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 4%, 2.25rem);
    text-align: center;
  }

  .fig--light .fig__ph {
    background: linear-gradient(150deg, #efe6d8 0%, var(--wood-1) 100%);
    color: #453423;
  }
  .fig--mid .fig__ph {
    background: linear-gradient(150deg, var(--wood-1) 0%, var(--wood-2) 55%, var(--wood-3) 100%);
    color: #fdf8f0;
  }
  .fig--dark .fig__ph {
    background: linear-gradient(150deg, var(--wood-3) 0%, #3a2c1e 60%, var(--ember) 100%);
    color: #f0e6d6;
  }

  /* slat motif, carried through to the placeholders */
  .fig__grain {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.16) 0 1px,
      transparent 1px 9px
    );
    opacity: 0.55;
    pointer-events: none;
  }

  .fig__body {
    position: relative;
    max-width: 30ch;
  }

  .fig__tag {
    display: inline-block;
    font-size: 0.625rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    padding: 0.4rem 0.85rem;
    border: 1px solid currentColor;
    opacity: 0.85;
    margin-bottom: 1rem;
  }

  .fig__note {
    font-size: 0.8125rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.92;
  }
</style>
