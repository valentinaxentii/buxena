---
import Figure from './Figure.astro';

interface Props {
  name: string;
  blurb: string;
  href: string;
  note?: string;
  count?: number;
}
const { name, blurb, href, note, count } = Astro.props;
---

<a class="ccard" href={href}>
  <div class="ccard__media">
    <Figure alt={name} note={note ?? `${name} — representative collection image`} ratio="4 / 5" tone="mid" />
    <span class="ccard__slats" aria-hidden="true"></span>
  </div>
  <div class="ccard__body">
    <h3 class="ccard__name">{name}</h3>
    <p class="ccard__blurb">{blurb}</p>
    <span class="ccard__more">
      View collection
      {typeof count === 'number' && <span class="ccard__count">{count}</span>}
    </span>
  </div>
</a>

<style>
  .ccard {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ccard__media { position: relative; overflow: hidden; }

  .ccard__media :global(.fig) {
    transition: transform 1.1s var(--ease);
  }
  .ccard:hover .ccard__media :global(.fig),
  .ccard:focus-visible .ccard__media :global(.fig) {
    transform: scale(1.035);
  }

  /* The slat motif as a hover reveal — the cladding retracts.
     Gated behind `hover: hover` so touch devices never sit under a permanent
     overlay on the photography. Kept light so real images stay readable. */
  .ccard__slats { display: none; }

  @media (hover: hover) and (pointer: fine) {
    .ccard__slats {
      display: block;
      position: absolute;
      inset: 0;
      background-image: repeating-linear-gradient(
        to bottom,
        rgba(27, 25, 23, 0.18) 0 1px,
        transparent 1px 10px
      );
      opacity: 1;
      transition: opacity 0.9s var(--ease);
      pointer-events: none;
    }
    .ccard:hover .ccard__slats,
    .ccard:focus-visible .ccard__slats { opacity: 0; }
  }

  .ccard__body { padding-top: 1.5rem; }

  .ccard__name {
    font-size: var(--t-h3);
    margin-bottom: 0.6rem;
  }

  .ccard__blurb {
    font-size: var(--t-small);
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 1.1rem;
  }
  .band--ember .ccard__blurb { color: var(--muted-dark); }

  .ccard__more {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: var(--t-label);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--bronze-ink);
    padding-bottom: 0.3rem;
    border-bottom: 1px solid transparent;
    transition: border-color 0.4s var(--ease);
  }
  .band--ember .ccard__more { color: var(--bronze-soft); }
  .ccard:hover .ccard__more { border-bottom-color: currentColor; }

  .ccard__count {
    font-family: var(--font-display);
    font-size: 0.85rem;
    opacity: 0.7;
    letter-spacing: 0;
  }
</style>
