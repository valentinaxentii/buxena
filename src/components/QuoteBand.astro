---
interface Props {
  heading?: string;
  body?: string;
}
const {
  heading = 'Tell us about your space',
  body = 'Send us the room, the deck or the corner of the garden you have in mind. We will come back with options that fit it, and a written quote.',
} = Astro.props;
---

<section class="band band--ember qband">
  <div class="shell shell--narrow center">
    <span class="slats mx-auto qband__slats" aria-hidden="true"></span>
    <h2 class="h2">{heading}</h2>
    <p class="lead qband__body">{body}</p>
    <a class="btn btn--bronze" href="/quote/">Request a Quote</a>
  </div>
</section>

<style>
  .qband__slats { color: var(--bronze-soft); opacity: 0.6; margin-bottom: 2rem; }
  .qband__body { margin: 1.5rem auto 2.5rem; max-width: 40em; }
</style>
