---
import { site, nav, categories, publicEmail, showDev } from '../data/site';
import { getCollection } from 'astro:content';

// Only list collections that actually contain a model.
const models = await getCollection('saunas', ({ data }) => !data.draft);
const liveCategories = categories.filter((c) => models.some((m) => m.data.category === c.id));
const year = new Date().getFullYear();
---

<footer class="ftr">
  <div class="shell">
    <div class="ftr__top">
      <div class="ftr__brand">
        <span class="ftr__mark">{site.name}</span>
        <p class="ftr__tag serif-italic">{site.tagline}</p>
        <span class="slats" aria-hidden="true"></span>
      </div>

      <div class="ftr__cols">
        <div>
          <h2 class="ftr__h">Collections</h2>
          <ul>
            {liveCategories.map((c) => (
              <li><a href={`/collections/${c.id}/`}>{c.name}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="ftr__h">Explore</h2>
          <ul>
            {nav.map((n) => (
              <li><a href={n.href}>{n.label}</a></li>
            ))}
            <li><a href="/quote/">Request a Quote</a></li>
          </ul>
        </div>

        <div>
          <h2 class="ftr__h">Enquiries</h2>
          <ul>
            {publicEmail && <li><a href={`mailto:${publicEmail}`}>{publicEmail}</a></li>}
            {site.phone && <li><a href={`tel:${site.phone.replace(/[^+\d]/g, '')}`}>{site.phone}</a></li>}
            {site.city && <li><span class="ftr__plain">{site.city}</span></li>}
            {site.instagram && <li><a href={site.instagram} rel="noopener">Instagram</a></li>}
            <li><a href="/quote/">Request a Quote</a></li>
            <li><span class="ftr__plain">Serving the United States</span></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="ftr__rule slats--rule" aria-hidden="true"></div>

    <div class="ftr__base">
      <p>© {year} {site.name}. All rights reserved.</p>
      {showDev && (
        <ul class="ftr__legal">
          <li><a href="/privacy/">Privacy</a></li>
          <li><a href="/terms/">Terms</a></li>
        </ul>
      )}
    </div>
  </div>
</footer>

<style>
  .ftr {
    background: var(--ember);
    color: var(--muted-dark);
    padding-block: clamp(3.5rem, 2rem + 5vw, 6rem) 2.5rem;
    font-size: var(--t-small);
  }

  .ftr__top {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.6fr);
    gap: clamp(2.5rem, 1rem + 5vw, 6rem);
    margin-bottom: clamp(2.5rem, 1.5rem + 3vw, 4.5rem);
  }

  .ftr__mark {
    display: block;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 1.25rem;
    letter-spacing: 0.42em;
    text-indent: 0.42em;
    color: var(--linen);
  }

  .ftr__tag {
    font-size: 1.15rem;
    color: var(--bronze-soft);
    margin: 0.9rem 0 1.6rem;
  }

  .ftr__brand .slats { color: var(--bronze-soft); opacity: 0.5; }

  .ftr__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 0.6rem + 2.6vw, 3rem);
  }

  .ftr__h {
    font-family: var(--font-sans);
    font-size: var(--t-label);
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--bronze-soft);
    margin: 0 0 1.4rem;
  }

  .ftr__cols li + li { margin-top: 0.7rem; }

  .ftr a {
    text-decoration: none;
    color: var(--muted-dark);
    transition: color 0.35s var(--ease);
  }
  .ftr a:hover { color: var(--linen); }
  .ftr__plain { color: var(--muted-dark); opacity: 0.75; }

  .ftr__rule { color: var(--bronze-soft); margin-bottom: 2rem; }

  .ftr__base {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8125rem;
  }
  .ftr__base p { margin: 0; }
  .ftr__legal { display: flex; gap: 1.75rem; }

  @media (max-width: 860px) {
    .ftr__top { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .ftr__cols { grid-template-columns: 1fr; gap: 2.25rem; }
  }
</style>
