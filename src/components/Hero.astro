---
import Figure from './Figure.astro';
import { site } from '../data/site';
---

<section class="hero">
  <div class="hero__media" aria-hidden="false">
    <Figure
      alt="A modern sauna at dusk, warm light spilling from a panoramic window"
      note="HERO — cinematic wide shot: contemporary cube sauna at blue hour, warm interior light through full-height glazing, natural landscape beyond. Shot horizontally, generous headroom for the wordmark."
      ratio="16 / 9"
      tone="dark"
      priority={true}
    />
    <div class="hero__scrim"></div>
  </div>

  <div class="hero__content">
    <div class="shell">
      <span class="slats hero__slats" aria-hidden="true"></span>
      <h1 class="hero__mark">
        <span class="hero__word">{site.name}</span>
        <span class="hero__tag">{site.tagline}</span>
      </h1>
      <p class="hero__lede">
        Saunas for the American home, drawn from a northern European
        tradition of quiet rooms, warm timber and unhurried heat.
      </p>
      <div class="hero__actions">
        <a class="btn btn--bronze" href="/saunas/">Explore the Saunas</a>
        <a class="btn btn--outline" href="/quote/">Request a Quote</a>
      </div>
    </div>
  </div>

  <a class="hero__scroll" href="#intro" aria-label="Scroll to introduction">
    <span class="hero__scroll-line" aria-hidden="true"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: clamp(34rem, 92svh, 56rem);
    display: grid;
    align-items: end;
    background: var(--ember);
    color: var(--linen);
    overflow: hidden;
  }

  .hero__media { position: absolute; inset: 0; }
  .hero__media :global(.fig) { width: 100%; height: 100%; aspect-ratio: auto; }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(20, 18, 16, 0.88) 0%,
      rgba(20, 18, 16, 0.55) 42%,
      rgba(20, 18, 16, 0.35) 100%
    );
  }

  .hero__content {
    position: relative;
    width: 100%;
    padding-block: clamp(6rem, 4rem + 9vw, 9rem) clamp(4rem, 2.5rem + 5vw, 7rem);
  }

  .hero__slats { color: var(--bronze-soft); opacity: 0.6; margin-bottom: 2.25rem; }

  .hero__mark { display: grid; gap: clamp(0.75rem, 0.4rem + 1vw, 1.5rem); }

  .hero__word {
    font-family: var(--font-sans);
    font-weight: 200;
    font-size: var(--t-hero);
    line-height: 0.95;
    letter-spacing: 0.16em;
    text-indent: 0.16em;
    color: var(--linen);
    /* the one orchestrated page-load moment: heat expanding */
    animation: expand 2.1s var(--ease) both;
  }

  .hero__tag {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.35rem, 0.95rem + 1.7vw, 2.5rem);
    line-height: 1.2;
    color: var(--bronze-soft);
    animation: rise 1.4s var(--ease) 0.55s both;
  }

  .hero__lede {
    max-width: 30em;
    margin: clamp(1.5rem, 1rem + 1.6vw, 2.5rem) 0 0;
    color: rgba(246, 242, 234, 0.82);
    font-size: var(--t-lead);
    animation: rise 1.4s var(--ease) 0.75s both;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: clamp(2rem, 1.4rem + 1.8vw, 3rem);
    animation: rise 1.4s var(--ease) 0.95s both;
  }
  .hero__actions .btn--outline { color: var(--linen); }

  .hero__scroll {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    height: 4.5rem;
    width: 3rem;
    display: grid;
    place-items: end center;
  }
  .hero__scroll-line {
    width: 1px;
    height: 3.25rem;
    background: linear-gradient(to bottom, transparent, var(--bronze-soft));
    animation: drop 2.6s var(--ease) infinite;
    transform-origin: bottom;
  }

  @keyframes expand {
    from { opacity: 0; letter-spacing: 0.015em; }
    to { opacity: 1; letter-spacing: 0.16em; }
  }
  @keyframes rise {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: none; }
  }
  @keyframes drop {
    0%, 100% { transform: scaleY(0.35); opacity: 0.35; }
    50% { transform: scaleY(1); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__word, .hero__tag, .hero__lede, .hero__actions, .hero__scroll-line {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 700px) {
    .hero__scroll { display: none; }
    .hero__actions .btn { flex: 1 1 auto; justify-content: center; }
  }
</style>
