---
import { categories } from '../data/site';
import { getCollection } from 'astro:content';

interface Props {
  /** Pre-selects a model when the form is embedded on a product page. */
  preselect?: string;
  compact?: boolean;
}
const { preselect, compact = false } = Astro.props;

const saunas = (await getCollection('saunas', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<!--
  Netlify Forms.
  `data-netlify="true"` makes Netlify detect and host this form at build time —
  submissions land in the Netlify dashboard, no backend required.
  `netlify-honeypot` names the invisible anti-spam field.
-->
<form
  class={`qform ${compact ? 'qform--compact' : ''}`}
  name="quote"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action="/thank-you/"
>
  <input type="hidden" name="form-name" value="quote" />

  <p class="qform__hp">
    <label>Leave this field empty <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
  </p>

  <div class="qform__grid">
    <div class="field">
      <label for="q-name">Name <span aria-hidden="true">*</span></label>
      <input id="q-name" name="name" type="text" required autocomplete="name" />
    </div>

    <div class="field">
      <label for="q-email">Email <span aria-hidden="true">*</span></label>
      <input id="q-email" name="email" type="email" required autocomplete="email" />
    </div>

    <div class="field">
      <label for="q-phone">Phone</label>
      <input id="q-phone" name="phone" type="tel" autocomplete="tel" />
    </div>

    <div class="field">
      <label for="q-zip">ZIP code <span aria-hidden="true">*</span></label>
      <input id="q-zip" name="zip" type="text" inputmode="numeric" required autocomplete="postal-code" />
      <span class="field__hint">Delivery cost depends on where the sauna is going.</span>
    </div>

    <div class="field">
      <label for="q-placement">Placement</label>
      <select id="q-placement" name="placement">
        <option value="">No preference yet</option>
        <option value="outdoor">Outdoor</option>
        <option value="indoor">Indoor</option>
        <option value="unsure">Not sure</option>
      </select>
    </div>

    <div class="field">
      <label for="q-model">Model or collection of interest</label>
      <select id="q-model" name="model">
        <option value="">Undecided — please advise</option>
        {categories.map((c) => (
          <option value={c.name} selected={preselect === c.name}>{c.name}</option>
        ))}
        {saunas.length > 0 && (
          <optgroup label="Specific models">
            {saunas.map((s) => (
              <option value={s.data.title} selected={preselect === s.data.title}>{s.data.title}</option>
            ))}
          </optgroup>
        )}
      </select>
    </div>

    <div class="field">
      <label for="q-people">People it should seat</label>
      <select id="q-people" name="capacity">
        <option value="">Not sure</option>
        <option value="1-2">1–2</option>
        <option value="3-4">3–4</option>
        <option value="5-6">5–6</option>
        <option value="7+">7 or more</option>
      </select>
    </div>

    <div class="field">
      <label for="q-timeline">Timeline</label>
      <select id="q-timeline" name="timeline">
        <option value="">Not set</option>
        <option value="asap">As soon as possible</option>
        <option value="1-3-months">1–3 months</option>
        <option value="3-6-months">3–6 months</option>
        <option value="researching">Still researching</option>
      </select>
    </div>

    <div class="field field--full">
      <label for="q-message">Tell us about the space</label>
      <textarea id="q-message" name="message" rows="5" placeholder="Dimensions, access, what the surroundings look like, anything you already know you want."></textarea>
    </div>
  </div>

  <div class="qform__foot">
    <button class="btn btn--bronze" type="submit">Send request</button>
    <p class="qform__note">
      We use your details to answer this enquiry. Nothing else.
    </p>
  </div>
</form>

<style>
  .qform__hp { position: absolute; left: -9999px; }

  .qform__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 2rem;
  }

  .field { display: grid; gap: 0.55rem; }
  .field--full { grid-column: 1 / -1; }

  .field label {
    font-size: var(--t-label);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .field label span { color: var(--bronze-ink); }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    color: var(--ink);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--line);
    padding: 0.7rem 0;
    width: 100%;
    border-radius: 0;
    transition: border-color 0.4s var(--ease);
  }
  .field textarea {
    border: 1px solid var(--line);
    padding: 0.9rem 1rem;
    resize: vertical;
    line-height: 1.7;
  }
  .field select { appearance: none; cursor: pointer; }

  .field input:hover,
  .field select:hover,
  .field textarea:hover { border-color: var(--muted); }
  .field input:focus,
  .field select:focus,
  .field textarea:focus { border-color: var(--bronze); }

  .field__hint { font-size: 0.75rem; color: var(--muted); opacity: 0.85; }

  .qform__foot {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem 2rem;
  }
  .qform__note { font-size: 0.8125rem; color: var(--muted); margin: 0; }

  @media (max-width: 640px) {
    .qform__grid { grid-template-columns: 1fr; }
  }
</style>
