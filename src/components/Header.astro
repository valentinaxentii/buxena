---
import { nav, site } from '../data/site';

interface Props { overHero?: boolean; }
const { overHero = false } = Astro.props;

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class={`hdr ${overHero ? 'hdr--over' : ''}`} data-header>
  <div class="hdr__inner">
    <a class="wordmark" href="/" aria-label={`${site.name} home`}>{site.name}</a>

    <nav class="hdr__nav" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="hdr__end">
      <a class="btn btn--bronze hdr__cta" href="/quote/">Request a Quote</a>
      <button class="burger" type="button" aria-expanded="false" aria-controls="mobile-nav" data-burger>
        <span class="sr-only">Open menu</span>
        <span class="burger__bar" aria-hidden="true"></span>
        <span class="burger__bar" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<div class="drawer" id="mobile-nav" hidden data-drawer>
  <nav aria-label="Mobile">
    <ul>
      {nav.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>
  </nav>
  <a class="btn btn--bronze drawer__cta" href="/quote/">Request a Quote</a>
</div>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--linen);
    border-bottom: 1px solid var(--line);
    transition: background-color 0.5s var(--ease), border-color 0.5s var(--ease),
      color 0.5s var(--ease);
  }

  /* transparent over a dark hero, until scrolled */
  .hdr--over {
    position: fixed;
    inset-inline: 0;
    background: transparent;
    border-bottom-color: transparent;
    color: var(--linen);
  }
  .hdr--over.is-stuck {
    background: var(--linen);
    border-bottom-color: var(--line);
    color: var(--ink);
  }

  .hdr__inner {
    max-width: var(--shell);
    margin-inline: auto;
    padding: 0 var(--gutter);
    height: clamp(4.25rem, 3.4rem + 2.2vw, 5.75rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .wordmark {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1.05rem, 0.9rem + 0.5vw, 1.3rem);
    letter-spacing: 0.42em;
    text-indent: 0.42em;
    text-decoration: none;
    white-space: nowrap;
  }

  .hdr__nav ul {
    display: flex;
    gap: clamp(1.4rem, 0.6rem + 1.9vw, 2.75rem);
  }

  .hdr__nav a {
    font-size: var(--t-label);
    letter-spacing: 0.19em;
    text-transform: uppercase;
    text-decoration: none;
    padding-block: 0.4rem;
    border-bottom: 1px solid transparent;
    transition: border-color 0.35s var(--ease), opacity 0.35s var(--ease);
    opacity: 0.82;
  }
  .hdr__nav a:hover { opacity: 1; border-bottom-color: currentColor; }
  .hdr__nav a[aria-current='page'] { opacity: 1; border-bottom-color: var(--bronze); }

  .hdr__end { display: flex; align-items: center; gap: 1rem; }
  .hdr__cta { padding: 0.85rem 1.5rem; }

  .burger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.6rem 0.2rem;
    width: 2.1rem;
  }
  .burger__bar {
    display: block;
    height: 1px;
    background: currentColor;
    transition: transform 0.4s var(--ease), opacity 0.3s var(--ease);
  }
  .burger__bar + .burger__bar { margin-top: 6px; }
  .burger[aria-expanded='true'] .burger__bar:first-child { transform: translateY(3.5px) rotate(45deg); }
  .burger[aria-expanded='true'] .burger__bar:last-child { transform: translateY(-3.5px) rotate(-45deg); }

  /* --- drawer --- */
  .drawer {
    position: fixed;
    inset: clamp(4.25rem, 3.4rem + 2.2vw, 5.75rem) 0 auto 0;
    z-index: 99;
    background: var(--linen);
    border-bottom: 1px solid var(--line);
    padding: 1.5rem var(--gutter) 2.5rem;
    display: grid;
    gap: 1.5rem;
  }
  .drawer[hidden] { display: none; }
  .drawer ul { display: grid; }
  .drawer a {
    display: block;
    font-family: var(--font-display);
    font-size: 1.6rem;
    text-decoration: none;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
  }
  .drawer__cta { justify-content: center; color: #fff; border-bottom: none; font-family: var(--font-sans); font-size: var(--t-label); }

  @media (max-width: 1000px) {
    .hdr__nav { display: none; }
    .burger { display: block; }
    .hdr__cta { display: none; }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const burger = document.querySelector<HTMLButtonElement>('[data-burger]');
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');

  if (header?.classList.contains('hdr--over')) {
    const onScroll = () => header.classList.toggle('is-stuck', window.scrollY > 40);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const setOpen = (open: boolean) => {
    if (!burger || !drawer) return;
    burger.setAttribute('aria-expanded', String(open));
    drawer.hidden = !open;
    burger.querySelector('.sr-only')!.textContent = open ? 'Close menu' : 'Open menu';

    // On the homepage the header sits transparent over a dark hero with light
    // text. The drawer is cream, so force the solid state while it is open or
    // the burger and wordmark disappear against it.
    if (header?.classList.contains('hdr--over')) {
      if (open) header.classList.add('is-stuck');
      else header.classList.toggle('is-stuck', window.scrollY > 40);
    }

    document.body.style.overflow = open ? 'hidden' : '';
  };

  burger?.addEventListener('click', () => {
    setOpen(burger.getAttribute('aria-expanded') !== 'true');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && burger?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      burger.focus();
    }
  });

  // close the drawer if the viewport grows past the breakpoint
  window.matchMedia('(min-width: 1001px)').addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
  });
</script>
